  "operator_principles": {
    "one_at_a_time": "Only one overlay should be on the strip at any time. Firing a new one auto-clears the current.",
    "clear_before_fire": "When transitioning between overlays, allow the current to fade out (300ms) before firing the next.",
    "manual_overrides_auto": "If an overlay is taking too long to clear because content drifted, hit manual clear. Auto-clear timers are sensible defaults, not laws.",
    "quick_fire_search": "Anything not pre-cued (a surprise guest, an unplanned testimony) can be fired from the search/library. Don't panic — search by person or section name.",
    "when_drift_happens": "If the programme drifts off schedule, the cue list still works — cues are tied to programme items, not clock times. Just stay with the current item's cue stack."
  }
